# Copy to .env and fill in values

# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=tumour_detector

# URL of the ML service (Google Cloud Run URL in production)
ML_SERVICE_URL=https://ml-service-xxxxxxxxxx-ew.a.run.app

# Comma-separated list of allowed CORS origins
# In production, set this to your Vercel URL
CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]
